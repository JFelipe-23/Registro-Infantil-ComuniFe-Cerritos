{% extends "base.jinja2" %}

{% block title %}Registro Staff - {{ community_name | default('Bienvenido') }}{% endblock %}

{% block extra_css %}
    .nav-top { width: 100%; display: flex; justify-content: space-between; margin-bottom: 40px; }
    .header-text { margin-bottom: 40px; width: 100%; }
    .input-box {
        width: 100%; background: #111; border: 1px solid #333;
        border-radius: 15px; padding: 20px; display: flex; align-items: center;
        margin-top: 10px;
    }
    .input-box input, .input-box select {
        background: transparent; border: none; color: #fff;
        width: 100%; padding-left: 15px; font-size: 1.1rem; outline: none;
    }
    .input-box select { color: #777; }
    .input-box select option { background: #111; color: #fff; }
    .divider-orb { margin: 30px 0; text-align: center; color: #333; position: relative; }
    .divider-orb::before { content: ""; position: absolute; top: 50%; left: 0; width: 45%; border-bottom: 1px solid #222; }
    .divider-orb::after { content: ""; position: absolute; top: 50%; right: 0; width: 45%; border-bottom: 1px solid #222; }
{% endblock %}

{% block content %}
<div class="nav-top">
    <a href="/staff-admin/home" style="color: #888; text-decoration: none;">❮ Volver</a>
    <img src="{{ url_for('static', filename='img/logo.png') }}" class="img-fluid" style="width: 35px; height: 35px;">
</div>

<div class="header-text">
    <h1 style="font-size: 2.5rem; margin-bottom: 10px;">Crear Salón</h1>
    <p style="color: #777;">Registra un nuevo salón en el sistema.</p>
</div>

<form style="width: 100%;" method="POST" novalidate>
    {{ form.hidden_tag() }}
    
    <label style="font-size: 0.8rem; font-weight: bold; letter-spacing: 1px;">NOMBRE DEL SALÓN</label>
    <div class="input-box">
        <span>🏫</span>
        {% if form.nombre.errors %}
            {{ form.nombre(placeholder='Ej. Salón 1A', style='border: 1px solid #d32f2f;') }}
        {% else %}
            {{ form.nombre(placeholder='Ej. Salón 1A') }}
        {% endif %}
    </div>
    {% if form.nombre.errors %}
        <ul style="color: #d32f2f; font-size: 0.8rem; margin-top: 5px;">
        {% for error in form.nombre.errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <label style="font-size: 0.8rem; font-weight: bold; letter-spacing: 1px;">USUARIO</label>
    <div class="input-box">
        <span>👤</span>
        {% if form.usuario.errors %}
            {{ form.usuario(placeholder='Ej. salon123', style='border: 1px solid #d32f2f;') }}
        {% else %}
            {{ form.usuario(placeholder='Ej. salon123') }}
        {% endif %}
    </div>
    {% if form.usuario.errors %}
        <ul style="color: #d32f2f; font-size: 0.8rem; margin-top: 5px;">
        {% for error in form.usuario.errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <label style="font-size: 0.8rem; font-weight: bold; letter-spacing: 1px;">SUPERVISOR</label>
    <div class="input-box" style="display: flex; align-items: center; gap: 10px;">
        {{ form.es_supervisor(style='width: auto; margin-left: 10px;') }}
        <span style="color: #777; font-size: 1rem;">¿Es usuario supervisor?</span>
    </div>
    {% if form.es_supervisor.errors %}
        <ul style="color: #d32f2f; font-size: 0.8rem; margin-top: 5px;">
        {% for error in form.es_supervisor.errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}
    
    <label style="font-size: 0.8rem; font-weight: bold; letter-spacing: 1px;">CONTRASEÑA</label>
    <div class="input-box">
        <span>🔒</span>
        {% if form.contrasena.errors %}
            {{ form.contrasena(placeholder='Ej. contraseña123', style='border: 1px solid #d32f2f;') }}
        {% else %}
            {{ form.contrasena(placeholder='Ej. contraseña123') }}
        {% endif %}
    </div>
    {% if form.contrasena.errors %}
        <ul style="color: #d32f2f; font-size: 0.8rem; margin-top: 5px;">
        {% for error in form.contrasena.errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}

    <label style="font-size: 0.8rem; font-weight: bold; letter-spacing: 1px;">CONFIRMAR CONTRASEÑA</label>
    <div class="input-box">
        <span>🔒</span>
        {% if form.confirmacion.errors %}
            {{ form.confirmacion(placeholder='Confirmar contraseña', style='border: 1px solid #d32f2f;') }}
        {% else %}
            {{ form.confirmacion(placeholder='Confirmar contraseña') }}
        {% endif %}
    </div>
    {% if form.confirmacion.errors %}
        <ul style="color: #d32f2f; font-size: 0.8rem; margin-top: 5px;">
        {% for error in form.confirmacion.errors %}<li>{{ error }}</li>{% endfor %}
        </ul>
    {% endif %}
    
    {{ form.submit(class='btn-custom btn-white', value='Crear Usuario', style='width: 100%; margin-top: 30px; border: none;') }}
</form>

{% endblock %}